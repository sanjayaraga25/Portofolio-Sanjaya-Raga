{
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "rm -f .env && composer install --no-dev && npm install && npm run build"
    },
    "deploy": {
        "startCommand": "php artisan migrate --force --seed && php -S 0.0.0.0:\"$PORT\" -t public",
        "healthcheckPath": "/up",
        "restartPolicyType": "on_failure"
    }
}
